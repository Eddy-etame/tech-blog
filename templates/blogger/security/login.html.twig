{% extends 'base.html.twig' %}

{% block title %}Connexion blogger - Tech Blog{% endblock %}

{% block body %}
    <section class="auth-section">
        <h1>Espace blogger</h1>
        <p class="auth-subtitle">Connectez-vous pour accéder à votre espace blogger</p>

        {% if error %}
            <div class="alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('blogger_login_check') }}" class="auth-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="username">Email</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus autocomplete="email"
                    placeholder="votre@email.com">
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" required autocomplete="current-password"
                    placeholder="••••••••">
            </div>

            <div class="form-group form-group-checkbox">
                <label>
                    <input type="checkbox" name="_remember_me"> Se souvenir de moi
                </label>
            </div>

            <button type="submit" class="btn">Se connecter</button>
        </form>

        <p class="auth-footer">
            Pas encore de compte blogger ? <a href="{{ path('blogger_register') }}">S'inscrire</a>
        </p>
        <p class="auth-footer">
            <a href="{{ path('app_index') }}">Retour au site</a>
        </p>
    </section>
{% endblock %}
