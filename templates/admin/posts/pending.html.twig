{% extends 'admin/base.html.twig' %}

{% block title %}Articles en attente - Admin{% endblock %}

{% block dashboard_content %}
    <h1>Articles en attente</h1>

    {% if posts|length > 0 %}
        <div class="dashboard-table-wrapper">
            <table class="dashboard-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Auteur</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in posts %}
                        <tr>
                            <td><a href="{{ path('app_post_show', { id: post.id }) }}">{{ post.title }}</a></td>
                            <td><span class="status-badge status-pending">En attente</span></td>
                            <td>{{ post.publishedAt|date('d/m/Y H:i') }}</td>
                            <td>{{ post.author ? post.author.firstName ~ ' ' ~ post.author.lastName : 'Anonyme' }}</td>
                            <td class="actions-cell">
                                <form method="post" action="{{ path('admin_post_approve', { id: post.id }) }}" style="display:inline;">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_post_approve_' ~ post.id) }}">
                                    <button type="submit" class="btn" style="padding:0.35rem 0.6rem;font-size:0.85rem;">Approuver</button>
                                </form>
                                <form method="post" action="{{ path('admin_post_reject', { id: post.id }) }}" style="display:inline;" class="reject-inline-form"
                                    onsubmit="return confirm('Rejeter cet article ?');">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_post_reject_' ~ post.id) }}">
                                    <input type="text" name="rejection_reason" placeholder="Raison (opt.)" style="width:120px;padding:0.25rem;font-size:0.85rem;margin-right:0.25rem;">
                                    <button type="submit" class="btn btn-secondary" style="padding:0.35rem 0.6rem;font-size:0.85rem;">Rejeter</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p class="empty-state">Aucun article en attente de validation.</p>
    {% endif %}
{% endblock %}
