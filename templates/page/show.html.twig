{% extends 'base.html.twig' %}

{% block title %}{{ post.title|default('') }} - Tech Blog{% endblock %}

{% block reading_progress %}
<div id="reading-progress" class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar"></div>
</div>
{% endblock %}

{% block body %}
    <article>
        <h1>{{ post.title }}</h1>
        <p>
            Par {{ post.author ? post.author.firstName ~ ' ' ~ post.author.lastName : 'Anonyme' }}
            — Publié le {{ post.publishedAt|date('d/m/Y à H:i') }}
            {% if app.user and post.author and (not app.user.author or app.user.author.id != post.author.id) %}
                {% set subscribed = subscribed_to_author|default(false) %}
                {% if subscribed %}
                    <span class="subscribed-badge">Abonné</span>
                {% else %}
                    <form method="post" action="{{ path('app_alert_subscribe', {authorId: post.author.id}) }}" style="display:inline;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('alert_subscribe_' ~ post.author.id) }}">
                        <button type="submit" class="btn btn-sm">S'abonner aux articles de {{ post.author.firstName }} {{ post.author.lastName }}</button>
                    </form>
                {% endif %}
            {% endif %}
        </p>
        <div class="post-content">
            {{ post.content|nl2br }}
        </div>

        <section class="comments" id="comments-section">
            <h2>Commentaires ({{ post.comments|length }})</h2>
            <div id="comments-list" aria-live="polite">
                {% for comment in post.comments %}
                    <div class="comment">
                        <p><strong>{{ comment.authorName }}</strong> — {{ comment.createdAt|date('d/m/Y H:i') }}</p>
                        <p>{{ comment.content|nl2br }}</p>
                    </div>
                {% else %}
                    <p id="comments-empty">Aucun commentaire pour le moment.</p>
                {% endfor %}
            </div>

            <div class="comment-form" id="comment-form-wrapper">
                <h3>Ajouter un commentaire</h3>
                {{ form_start(form, {'action': path('app_post_show', {id: post.id}), 'method': 'POST', 'attr': {'data-turbo': 'false', 'data-controller': 'comment-form', 'data-action': 'submit.prevent->comment-form#handleSubmit'}}) }}
                {{ form_errors(form) }}
                {{ form_row(form.authorName) }}
                {{ form_row(form.content) }}
                <button type="submit" class="btn" data-comment-form-target="submitBtn">
                    <span class="btn-text" data-comment-form-target="btnText">Publier</span>
                </button>
                {{ form_end(form) }}
            </div>
        </section>
    </article>
    <p><a href="{{ path('app_index') }}" class="btn btn-secondary">Retour à l'accueil</a></p>
{% endblock %}

{% block comment_form %}
    {{ form_errors(form) }}
    {{ form_row(form.authorName) }}
    {{ form_row(form.content) }}
    <button type="submit" class="btn" data-comment-form-target="submitBtn">
        <span class="btn-text" data-comment-form-target="btnText">Publier</span>
    </button>
{% endblock %}

{% block success_stream %}
    <turbo-stream action="remove" targets="#comments-empty"></turbo-stream>
    <turbo-stream action="append" targets="#comments-list">
        <template>
            <div class="comment">
                <p><strong>{{ comment.authorName }}</strong> — {{ comment.createdAt|date('d/m/Y H:i') }}</p>
                <p>{{ comment.content|nl2br }}</p>
            </div>
        </template>
    </turbo-stream>
    <turbo-stream action="replace" targets="#comment-form-wrapper">
        <template>
            <div class="comment-form" id="comment-form-wrapper">
                <h3>Ajouter un commentaire</h3>
                {{ form_start(form, {'action': path('app_post_show', {id: post.id}), 'method': 'POST', 'attr': {'data-turbo': 'false', 'data-controller': 'comment-form', 'data-action': 'submit.prevent->comment-form#handleSubmit'}}) }}
                {{ block('comment_form') }}
                {{ form_end(form) }}
            </div>
        </template>
    </turbo-stream>
{% endblock %}

{% block validation_stream %}
    <turbo-stream action="replace" targets="#comment-form-wrapper">
        <template>
            <div class="comment-form" id="comment-form-wrapper">
                <h3>Ajouter un commentaire</h3>
                {{ form_start(form, {'action': path('app_post_show', {id: post.id}), 'method': 'POST', 'attr': {'data-turbo': 'false', 'data-controller': 'comment-form', 'data-action': 'submit.prevent->comment-form#handleSubmit'}}) }}
                {{ block('comment_form') }}
                {{ form_end(form) }}
            </div>
        </template>
    </turbo-stream>
{% endblock %}

{% block error_stream %}
    <turbo-stream action="prepend" targets="#comments-section">
        <template>
            <div class="alert-error">{{ errorMessage }}</div>
        </template>
    </turbo-stream>
{% endblock %}
