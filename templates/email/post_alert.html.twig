<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Nouvel article</title>
</head>
<body>
    <h1>Nouvel article de {{ authorName }}</h1>
    <h2>{{ postTitle }}</h2>
    <p>{{ excerpt }}</p>
    <p><a href="{{ postUrl }}">Lire l'article</a></p>
